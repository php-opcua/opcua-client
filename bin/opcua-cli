#!/usr/bin/env php
<?php

declare(strict_types=1);

$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
];

foreach ($autoloadPaths as $path) {
    if (file_exists($path)) {
        require $path;

        break;
    }
}

$app = new Gianfriaur\OpcuaPhpClient\Cli\Application();
exit($app->run($argv));
